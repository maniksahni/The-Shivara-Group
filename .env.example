# Railway MySQL reference variable
DATABASE_URL="${{MySQL.MYSQL_URL}}"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Public URL of the Railway service, for example:
NEXTAUTH_URL="https://your-app.up.railway.app"

# Google OAuth for CRM login
# Google Cloud Console redirect URI:
# https://your-app.up.railway.app/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# The only Google email allowed to access the CRM.
# Set this to Shivam Sahani's real Google/Gmail address in Railway.
CRM_ADMIN_EMAIL=""

# Optional: comma-separated list if more authorised Google accounts are added later.
CRM_GOOGLE_ALLOWED_EMAILS=""

# Optional: password used when prisma db seed creates/updates the admin.
SEED_ADMIN_PASSWORD=""
