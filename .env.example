# Railway MySQL reference variable
DATABASE_URL="${{MySQL.MYSQL_URL}}"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Public URL of the Railway service, for example:
NEXTAUTH_URL="https://your-app.up.railway.app"

# Admin email used by prisma db seed to create/update the CRM admin user.
CRM_ADMIN_EMAIL=""

# Password used when prisma db seed creates/updates the admin user.
SEED_ADMIN_PASSWORD=""
