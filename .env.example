# Railway MySQL reference variable
DATABASE_URL="${{MySQL.MYSQL_URL}}"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Public custom domain. Use your real production domain, not the Railway URL.
# Example: https://theshivaragroup.com
NEXTAUTH_URL="https://your-custom-domain.com"
NEXT_PUBLIC_SITE_URL="https://your-custom-domain.com"
SITE_URL="https://your-custom-domain.com"

# Admin email used by prisma db seed to create/update the CRM admin user.
CRM_ADMIN_EMAIL=""

# Password used when prisma db seed creates/updates the admin user.
SEED_ADMIN_PASSWORD=""
